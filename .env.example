# ─── Copy this to .env and fill in your values ────────────────────────────────

# ─── Database: shared dymphna-infrastructure Cloud SQL ────────────────────────
# VoIP gets its OWN database (dymphna_voip) in the existing Cloud SQL instance —
# create it with scripts/infra-db-setup.sql. We connect through the Cloud SQL Auth
# Proxy container, so the DATABASE_URL host is the proxy service name, not Cloud SQL.
# Find the connection name:  gcloud sql instances list --project=dymphna-infrastructure
INSTANCE_CONNECTION_NAME=dymphna-infrastructure:REGION:INSTANCE_NAME
DATABASE_URL=postgresql+asyncpg://voip:CHANGE_ME@cloud-sql-proxy:5432/dymphna_voip

# JWT — must EQUAL the EHR's NEXTAUTH_SECRET (so app login tokens validate here).
JWT_SECRET=change-me-in-production

# Asterisk AMI — must match manager.conf
ASTERISK_HOST=localhost
ASTERISK_PORT=5038
ASTERISK_USERNAME=dymphna_ami
ASTERISK_SECRET=change-me-in-production

# VoIP.ms API credentials (from voip.ms portal → Main Menu → API)
VOIPMS_API_USERNAME=your@email.com
VOIPMS_API_PASSWORD=your_api_password
VOIPMS_DID=5555551234             # your DID without +1

# S3 (for voicemail / recording storage)
S3_BUCKET=dymphna-voip-recordings
AWS_REGION=us-east-1
# AWS credentials via IAM role preferred; or set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY

# Apple VoIP Push (PushKit) — download .p8 key from Apple Developer portal
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.dymphna.app
APNS_USE_SANDBOX=false            # true for TestFlight / dev builds
# Place your AuthKey_KEYID.p8 file in ./secrets/apns_voip.p8

# Firebase Cloud Messaging (Android push)
FCM_SERVER_KEY=your_fcm_server_key

# ─── WebRTC softphone (SIP-over-WSS to Asterisk) ──────────────────────────────
# Public host + port the mobile app registers to (Asterisk wss listener).
SIP_WS_HOST=voip.dymphnacounseling.com
SIP_WS_PORT=8089
SIP_DOMAIN=voip.dymphnacounseling.com
# ICE servers handed to the app. STUN is enough for discovery; a TURN server
# (run coturn) is strongly recommended for reliable audio on cellular networks.
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=                       # e.g. turn:turn.dymphnacounseling.com:3478
TURN_USERNAME=
TURN_PASSWORD=
