; Asterisk AMI configuration — generated from this template by entrypoint.sh
; (envsubst injects ${ASTERISK_SECRET}). The FastAPI VoIP service connects here to
; originate/control calls. Port 5038 is NOT opened on the GCP firewall, so AMI is
; reachable only within the host/VPC.

[general]
enabled = yes
port = 5038
bindaddr = 0.0.0.0
displayconnects = yes

; FastAPI backend AMI user
[dymphna_ami]
secret = ${ASTERISK_SECRET}            ; from .env — must match voip-api's ASTERISK_SECRET
deny = 0.0.0.0/0.0.0.0
permit = 127.0.0.1/255.255.255.0
permit = 172.16.0.0/255.240.0.0        ; Docker bridge network (voip-api container)
read = all
write = all,originate
